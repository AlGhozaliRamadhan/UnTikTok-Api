{
  "name": "untiktok-api",
  "version": "1.0.7",
  "description": "Unofficial TikTok API wrapper in TypeScript (ported from Python)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "tiktok",
    "api",
    "scraper",
    "typescript",
    "playwright"
  ],
  "author": "AlGhozaliRamadhan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlGhozaliRamadhan/UnTikTok-Api.git"
  },
  "bugs": {
    "url": "https://github.com/AlGhozaliRamadhan/UnTikTok-Api/issues"
  },
  "homepage": "https://github.com/AlGhozaliRamadhan/UnTikTok-Api#readme",
  "dependencies": {
    "axios": "^1.17.0",
    "https-proxy-agent": "^9.1.0",
    "playwright": "^1.44.0"
  },
  "overrides": {
    "form-data": ">=4.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
