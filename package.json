{
  "name": "untiktok-api",
  "version": "1.0.8",
  "description": "Unofficial TikTok API wrapper in TypeScript (ported from Python)",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.esm.json && node scripts/rewrite-esm-extensions.mjs && node scripts/write-esm-package.mjs",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest",
    "test:run": "vitest run",
    "check:playwright-version": "node scripts/check-playwright-version.mjs",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "tiktok",
    "api",
    "scraper",
    "typescript",
    "playwright"
  ],
  "author": "AlGhozaliRamadhan",
  "license": "MIT",
  "engines": {
    "node": ">=20.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlGhozaliRamadhan/UnTikTok-Api.git"
  },
  "bugs": {
    "url": "https://github.com/AlGhozaliRamadhan/UnTikTok-Api/issues"
  },
  "homepage": "https://github.com/AlGhozaliRamadhan/UnTikTok-Api#readme",
  "dependencies": {
    "axios": "^1.17.0",
    "https-proxy-agent": "^9.1.0",
    "playwright": "1.61.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "form-data": ">=4.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  }
}
