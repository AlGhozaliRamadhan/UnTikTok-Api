# UnTikTok-Api environment variables (ADR-005).
# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# TikTok msToken cookie value, required for many authenticated endpoints.
# Lowercase `ms_token` is what this library's tests and source read;
# `MS_TOKEN` (uppercase) is NOT read by the library. Keep the casing.
ms_token=

# Update-notification opt-outs (see src/version-check.ts).
# The library warns on import when the local copy is behind npm.
# To silence the warning, set any of these to `1`:
#   UNTIKTOK_SKIP_VERSION_CHECK=1     # canonical, package-specific
#   NO_UPDATE_NOTIFIER=1              # update-notizer convention
# CI=true also disables the runtime check automatically.

